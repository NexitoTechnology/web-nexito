---
import { Image } from "astro:assets";
import Logo from "../assets/Logo.svg";
import JsonLD from "./JsonLD.astro";

// Datos estructurados del menú
const menuData = {
  logo: {
    src: Logo,
    alt: "Logo Nexito Technology",
    loading: "eager" as const,
  },
  services: [
    { title: "Power BI", url: "/servicios/power-bi" },
    { title: "Automatización", url: "/servicios/automatizacion" },
    { title: "Desarrollo IA", url: "/servicios/ia" },
    { title: "Consultoría Tecnologica", url: "/servicios/consultoria" },
    { title: "Servicios SAP", url: "/servicios/sap" },
    { title: "Business Intelligence", url: "/servicios/bi" },
  ],
};

// Schema para el menú de navegación
const navigationSchema = {
  "@type": "WebSite",
  name: "Nexito Technology",
  url: "https://nexito.technology", // URL directa de tu sitio
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: "https://nexito.technology/search?q={search_term_string}", // URL completa para búsqueda
    },
    "query-input": "required name=search_term_string",
  },
};
---

<header class="sticky top-0 w-full bg-white/95 backdrop-blur-md shadow-lg z-50 border-b border-gray-100">
  <JsonLD type="WebSite" data={navigationSchema} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-center h-20">
      {/* Logo */}
      <a 
        href="/" 
        class="flex-shrink-0 transform hover:scale-105 transition-transform duration-200" 
        aria-label="Ir a la página principal"
      >
        <Image
          src={menuData.logo.src}
          alt={menuData.logo.alt}
          loading={menuData.logo.loading}
          width={144}
          height={104}
          format="webp"
          quality={90}
          class="w-auto h-8 md:h-10"
        />
      </a>

      {/* Desktop Menu */}
      <nav class="hidden md:flex items-center gap-8" aria-label="Menú principal">
        <div class="relative group">
          <button
            class="flex items-center text-gray-600 hover:text-blue-600 font-medium transition-colors py-2"
            aria-expanded="false"
            aria-controls="desktop-services-menu"
            aria-haspopup="true"
          >
            Servicios
            <svg
              class="ml-1.5 h-4 w-4 transform group-hover:rotate-180 transition-transform duration-200"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
                clip-rule="evenodd"
              />
            </svg>
          </button>

          {/* Dropdown mejorado */}
          <div
            id="desktop-services-menu"
            class="absolute left-0 mt-1 w-64 bg-white rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top scale-95 group-hover:scale-100 border border-gray-100"
            role="menu"
            aria-orientation="vertical"
          >
            <div class="py-2">
              {menuData.services.map((service) => (
                
                  <a href={service.url}
                  class="flex items-center px-4 py-2.5 text-sm text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors"
                  role="menuitem"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-blue-600 opacity-0 transition-opacity duration-200 mr-2 group-hover:opacity-100"></span>
                  {service.title}
                </a>
              ))}
            </div>
          </div>
        </div>

        
          <a href="/blog"
          class="text-gray-600 hover:text-blue-600 font-medium transition-colors"
          aria-label="Ir al blog"
        >
          Blog
        </a>
        
        
        <a href="/contacto"
          class="inline-flex items-center justify-center px-5 py-2.5 font-medium text-white bg-gradient-to-r from-blue-600 to-blue-700 rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-200"
          aria-label="Contactar con nosotros"
        >
          Contacto
        </a>
      </nav>

      {/* Mobile menu button mejorado */}
      <button
        type="button"
        class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-600 hover:text-blue-600 hover:bg-blue-50 transition-colors"
        id="menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú móvil"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile menu mejorado */}
  <div
    class="hidden md:hidden border-t border-gray-100"
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú móvil"
  >
    <div class="px-4 py-3 space-y-3">
      <button
        class="w-full flex items-center justify-between px-4 py-2.5 text-base font-medium text-gray-600 hover:text-blue-600 rounded-lg hover:bg-blue-50 transition-colors"
        id="mobile-services-btn"
        aria-expanded="false"
        aria-controls="mobile-services-menu"
      >
        Servicios
        <svg
          class="h-4 w-4 transform transition-transform duration-200"
          id="mobile-services-icon"
          viewBox="0 0 20 20"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
            clip-rule="evenodd"
          />
        </svg>
      </button>

      <div class="hidden pl-4 space-y-2" id="mobile-services-menu" role="menu">
        {menuData.services.map((service) => (
          
          <a href={service.url}
            class="flex items-center px-4 py-2.5 text-base text-gray-600 hover:text-blue-600 rounded-lg hover:bg-blue-50 transition-colors"
            role="menuitem"
          >
            {service.title}
          </a>
        ))}
      </div>

      
      <a href="/blog"
        class="block px-4 py-2.5 text-base font-medium text-gray-600 hover:text-blue-600 rounded-lg hover:bg-blue-50 transition-colors"
        role="menuitem"
      >
        Blog
      </a>
      
      
      <a href="/contacto"
        class="block text-center bg-gradient-to-r from-blue-600 to-blue-700 text-white px-4 py-3 rounded-lg font-medium hover:shadow-lg transition-shadow"
        role="menuitem"
      >
        Contacto
      </a>
    </div>
  </div>
</header>

<script>
  // Toggle mobile menu con animación
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const servicesBtn = document.getElementById("mobile-services-btn");
  const servicesMenu = document.getElementById("mobile-services-menu");
  const servicesIcon = document.getElementById("mobile-services-icon");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  servicesBtn?.addEventListener("click", () => {
    servicesMenu?.classList.toggle("hidden");
    servicesIcon?.classList.toggle("rotate-180");
  });
</script>