// Schema para la página
const serviceSchema = {
  "@type": "Service",
  name: automatizacionData.hero.title,
  description: automatizacionData.description,
  provider: {
    "@type": "Organization",
    name: "Nexito Technology"
  },
  serviceType: "Process Automation",
  areaServed: "ES"
};
---

<Layout title={automatizacionData.title} description={automatizacionData.description}>
  <JsonLD type="Service" data={serviceSchema} />

  <Hero
    title={automatizacionData.hero.title}
    subtitle={automatizacionData.hero.subtitle}
    description={automatizacionData.hero.description}
    tag={automatizacionData.hero.tag}
  >
    <!-- Hero content -->
  </Hero>

  <Divider />

  <Features {...automatizacionData.features} />

  <Divider />

  <UseCases {...automatizacionData.useCases} />

  <Divider />

  <Benefits {...automatizacionData.benefits} />

  <Divider />

  <section class="py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <CTASection {...automatizacionData.cta} />
    </div>
  </section>
  
  <Divider />

  <Process {...automatizacionData.process} />

  <Divider />

  <FAQ {...automatizacionData.faq} />

  <FaqCtaServices />

  <Divider />

  <ContactServices />

  <Divider />

</Layout>