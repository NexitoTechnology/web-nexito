    description: "Transforma tus procesos manuales en flujos digitales eficientes y escalables",
    tag: "🚀 Impulsa tu Eficiencia Operativa"
  },

  features: {
    title: "Soluciones",
    subtitle: "de Automatización",
    description: "Herramientas avanzadas para optimizar tu negocio",
    tag: "Características",
    features: [
      {
        title: "Automatización de Flujos",
        description: "Digitaliza y automatiza tus procesos empresariales",
        icon: "⚡"
      },
      {
        title: "Integración Total",
        description: "Conecta todas tus aplicaciones y sistemas",
        icon: "🔄"
      },
      {
        title: "Análisis de Datos",
        description: "Obtén insights valiosos de tus procesos",
        icon: "📊"
      },
      {
        title: "Escalabilidad",
        description: "Crece sin límites con procesos optimizados",
        icon: "📈"
      }
    ]
  },

  useCases: {
    title: "Casos de",
    subtitle: "Aplicación",
    description: "Descubre cómo la automatización transforma diferentes áreas",
    tag: "Ejemplos Prácticos",
    useCases: [
      {
        title: "Gestión Documental",
        description: "Automatización del procesamiento de documentos",
        image: "/images/finance-automation.webp",
        link: "/blog/caso-exito-automatizacion-documental", // Opcional
        linkText: "Ver caso completo" // Opcional
      },
      {
        title: "Procesos de Ventas",
        description: "Optimización del ciclo de ventas completo",
        image: "/images/hr-automation.webp",
        link: "/casos/ventas", // linkText es opcional, usará el valor por defecto
        linkText: "Ver caso completo"
      },
      {
        title: "Servicio al Cliente",
        description: "Automatización de atención y soporte",
        image: "/images/customer-service-automation.webp",
        link: "/casos/atencion-cliente",
        linkText: "Ver caso completo"
      }
    ],
    extraCTA: { // Opcional
      text: "Explora más casos de éxito",
      href: "#calendar-booking"
    }
  },

  benefits: {
    title: "Ventajas",
    subtitle: "para tu Empresa",
    description: "Beneficios tangibles que transformarán tu operación",
    tag: "Beneficios",
    benefits: [
