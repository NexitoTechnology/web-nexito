---
// src/pages/servicios/power-bi.astro
import Layout from '../../layouts/Layout.astro';
import JsonLD from '../../components/JsonLD.astro';
import ContactForm from '../../components/ContactForm.astro';

// Datos estructurados para la página
const powerBIData = {
  title: "Servicios Power BI | Nexito Technology",
  description: "Convierte tus datos en decisiones estratégicas con nuestros servicios de Power BI. Dashboards personalizados, informes en tiempo real y análisis avanzado de datos.",
  heroTitle: "Servicios Power BI",
  heroSubtitle: "Transforma tus Datos en Decisiones Inteligentes",
  features: [
    {
      title: "Dashboards Interactivos",
      description: "Visualizaciones dinámicas que permiten explorar tus datos en tiempo real",
      icon: "📊"
    },
    {
      title: "Integración de Datos",
      description: "Conecta y unifica datos de múltiples fuentes en un solo lugar",
      icon: "🔄"
    },
    {
      title: "Informes Automatizados",
      description: "Generación y distribución automática de informes personalizados",
      icon: "📈"
    },
    {
      title: "Analytics Avanzado",
      description: "Análisis predictivo y descubrimiento de patrones en tus datos",
      icon: "🎯"
    }
  ],
  benefits: [
    "Toma de decisiones basada en datos",
    "Reducción del tiempo de análisis",
    "Mejora en la precisión de reportes",
    "Acceso en tiempo real a información crítica",
    "Colaboración mejorada entre equipos"
  ],
  useCases: [
    {
      title: "Finanzas",
      description: "Análisis financiero y reportes de KPIs",
      image: "/images/finance-dashboard.jpg"
    },
    {
      title: "Ventas",
      description: "Seguimiento de ventas y análisis de rendimiento",
      image: "/images/sales-dashboard.jpg"
    },
    {
      title: "Marketing",
      description: "Análisis de campañas y ROI",
      image: "/images/marketing-dashboard.jpg"
    }
  ],
  process: [
    {
      step: 1,
      title: "Evaluación",
      description: "Análisis de necesidades y objetivos"
    },
    {
      step: 2,
      title: "Diseño",
      description: "Creación de mockups y arquitectura de datos"
    },
    {
      step: 3,
      title: "Desarrollo",
      description: "Implementación y configuración"
    },
    {
      step: 4,
      title: "Pruebas",
      description: "Validación y ajustes"
    },
    {
      step: 5,
      title: "Despliegue",
      description: "Implementación y capacitación"
    }
  ],
  faq: [
    {
      question: "¿Qué es Power BI?",
      answer: "Power BI es una plataforma de análisis empresarial que permite visualizar sus datos y compartir información en toda su organización."
    },
    {
      question: "¿Cuánto tiempo toma implementar Power BI?",
      answer: "El tiempo de implementación varía según la complejidad del proyecto, pero típicamente toma entre 2-8 semanas."
    },
    // ... más preguntas frecuentes
  ]
};

// Schema para la página de servicio
const serviceSchema = {
  "@type": "Service",
  "name": powerBIData.heroTitle,
  "description": powerBIData.description,
  "provider": {
    "@type": "Organization",
    "name": "Nexito Technology"
  },
  "serviceType": "Business Intelligence Service",
  "areaServed": "ES"
};
---

<Layout 
  title={powerBIData.title}
  description={powerBIData.description}
>
  <JsonLD type="Service" data={serviceSchema} />
  
  <section class="relative py-20 overflow-hidden bg-gradient-to-b from-blue-900 to-blue-700">
    <div class="absolute inset-0 bg-grid-white/[0.05] bg-[size:20px_20px]"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 relative">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">
          {powerBIData.heroTitle}
          <span class="block text-blue-300 mt-2">{powerBIData.heroSubtitle}</span>
        </h1>
        <p class="text-xl text-blue-100 mb-8">
          Convierte tus datos en insights accionables con dashboards interactivos y reportes personalizados
        </p>
        <a 
          href="#contact" 
          class="inline-block bg-white text-blue-600 px-8 py-4 rounded-lg font-semibold hover:bg-blue-50 transition-colors"
        >
          Solicitar Demo Gratuita
        </a>
      </div>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Características Principales
        </h2>
        <p class="text-xl text-gray-600">
          Todo lo que necesitas para transformar tus datos en decisiones inteligentes
        </p>
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {powerBIData.features.map(feature => (
          <div class="bg-gray-50 p-6 rounded-xl">
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-xl font-semibold mb-2">{feature.title}</h3>
            <p class="text-gray-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Casos de Uso
        </h2>
        <p class="text-xl text-gray-600">
          Descubre cómo Power BI puede transformar tu negocio
        </p>
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {powerBIData.useCases.map(useCase => (
          <div class="bg-white rounded-xl overflow-hidden shadow-lg">
            <div class="aspect-video bg-gray-200">
              <img 
                src={useCase.image} 
                alt={useCase.title}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold mb-2">{useCase.title}</h3>
              <p class="text-gray-600">{useCase.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Proceso de Implementación
        </h2>
        <p class="text-xl text-gray-600">
          Un enfoque estructurado para garantizar el éxito
        </p>
      </div>
  
      <div class="relative">
        {/* Línea de conexión */}
        <div class="absolute top-1/2 left-0 w-full h-1 bg-blue-200 -translate-y-1/2 hidden md:block"></div>
  
        <div class="grid grid-cols-1 md:grid-cols-5 gap-8">
          {powerBIData.process.map(step => (
            <div class="relative">
              <div class="bg-white rounded-full w-12 h-12 flex items-center justify-center text-blue-600 font-bold text-xl border-4 border-blue-200 mx-auto z-10 relative">
                {step.step}
              </div>
              <div class="text-center mt-4">
                <h3 class="font-semibold mb-2">{step.title}</h3>
                <p class="text-gray-600 text-sm">{step.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  <section class="py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Preguntas Frecuentes
        </h2>
      </div>
  
      <div class="space-y-6">
        {powerBIData.faq.map(item => (
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h3 class="text-lg font-semibold mb-2">{item.question}</h3>
            <p class="text-gray-600">{item.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
  <section id="contact" class="py-20 bg-blue-900">
    <ContactForm />
  </section>
  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          Beneficios
        </h2>
        <p class="text-xl text-gray-600">
          Ventajas competitivas que obtendrás
        </p>
      </div>
  
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {powerBIData.benefits.map(benefit => (
          <div class="flex items-start space-x-4">
            <div class="flex-shrink-0">
              <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <p class="text-gray-700">{benefit}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>