---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import JsonLD from '../components/JsonLD.astro';
import { collections } from '../content/config';

interface BlogSchema {
  title: string;
  date: Date;
  description: string;
  image?: string;
  imageAlt?: string;
  tags?: string[];
  categoria?: string;
  lastModified?: Date;
  readingTime?: number;
  dificultad?: 'Básico' | 'Intermedio' | 'Avanzado';
  audiencia?: string[];
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: string;
  isPublished: boolean;
  featured: boolean;
  author: string;
  articulosRelacionados?: string[];
  serie?: string;
  ordenEnSerie?: number;
  requisitoPrevio?: string[];
  tiempoImplementacion?: string;
}

type BlogPost = CollectionEntry<'blog'> & {
  data: BlogSchema;
};

// Obtener todos los posts
const allPosts = (await getCollection('blog', ({ data }) => {
  return data.isPublished === true;
})) as BlogPost[];

// Obtener posts destacados
const featuredPosts = allPosts
  .filter(post => post.data.featured)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 2);

// Obtener posts regulares (no destacados)
const regularPosts = allPosts
  .filter(post => !post.data.featured)
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Obtener categorías únicas
const categorias = [...new Set(allPosts
  .filter(post => post.data.categoria !== undefined)
  .map(post => post.data.categoria)
)];

const title = "Blog | Nexito Technology";
const description = "Explora nuestros artículos sobre automatización, IA y transformación digital. Mantente al día con las últimas tendencias tecnológicas.";

// Schema para el listado de blog
const blogListSchema = {
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": new URL("/blog", Astro.site).toString(),
  "isPartOf": {
    "@type": "Website",
    "name": "Nexito Technology"
  },
  "about": {
    "@type": "Organization",
    "name": "Nexito Technology"
  },
  "hasPart": allPosts.map(post => ({
    "@type": "BlogPosting",
    "headline": post.data.title,
    "description": post.data.description,
    "datePublished": post.data.date.toISOString(),
    "dateModified": post.data.lastModified?.toISOString() || post.data.date.toISOString(),
    "url": new URL(`/blog/${post.slug}`, Astro.site).toString(),
    "author": {
      "@type": "Organization",
      "name": post.data.author
    }
  }))
};
---

<Layout title={title} description={description} type="website">
  <JsonLD type="WebPage" data={blogListSchema} />
  
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="text-center mb-16">
      <h1 class="text-5xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
        Blog de Nexito Technology
      </h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        Descubre las últimas tendencias en automatización, inteligencia artificial y transformación digital
      </p>
    </header>

    {featuredPosts.length > 0 && (
      <section class="mb-16">
        <h2 class="text-2xl font-semibold mb-8">Artículos Destacados</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {featuredPosts.map(post => (
            <article class="bg-white rounded-xl shadow-lg overflow-hidden">
              <a href={`/blog/${post.slug}`} class="block group">
                {post.data.image && (
                  <div class="relative aspect-video overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                <div class="p-6">
                  {post.data.categoria && (
                    <span class="inline-block px-3 py-1 text-sm font-medium text-blue-600 bg-blue-50 rounded-full mb-3">
                      {post.data.categoria}
                    </span>
                  )}
                  <h3 class="text-2xl font-bold mb-3 group-hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-gray-600 mb-4">{post.data.description}</p>
                  <div class="flex items-center justify-between text-sm text-gray-500">
                    <time datetime={post.data.date.toISOString()}>
                      {new Date(post.data.date).toLocaleDateString('es-ES', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                    {post.data.readingTime && (
                      <span>{post.data.readingTime} min de lectura</span>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )}

    <div class="grid lg:grid-cols-4 gap-8">
      {categorias.length > 0 && (
        <aside class="lg:col-span-1">
          <div class="sticky top-4">
            <h2 class="text-xl font-semibold mb-4">Categorías</h2>
            <nav class="space-y-2">
              {categorias.map(categoria => (
                <a
                href={`/blog/categoria/${(categoria ?? '').toLowerCase()}`}
                  class="block px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"
                >
                  {categoria}
                  <span class="text-sm text-gray-500 ml-2">
                    ({allPosts.filter(post => post.data.categoria === categoria).length})
                  </span>
                </a>
              ))}
            </nav>

            {['Básico', 'Intermedio', 'Avanzado'].some(nivel => 
              allPosts.some(post => post.data.dificultad === nivel)
            ) && (
              <div class="mt-8">
                <h2 class="text-xl font-semibold mb-4">Nivel</h2>
                <div class="space-y-2">
                  {['Básico', 'Intermedio', 'Avanzado'].map(nivel => (
                    <a
                      href={`/blog/nivel/${nivel.toLowerCase()}`}
                      class="block px-4 py-2 rounded-lg hover:bg-gray-100 transition-colors"
                    >
                      {nivel}
                      <span class="text-sm text-gray-500 ml-2">
                        ({allPosts.filter(post => post.data.dificultad === nivel).length})
                      </span>
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        </aside>
      )}

      <section class={categorias.length > 0 ? "lg:col-span-3" : "lg:col-span-4"}>
        <h2 class="text-2xl font-semibold mb-8">Últimos Artículos</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {regularPosts.map(post => (
            <article class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow duration-300">
              <a href={`/blog/${post.slug}`} class="block h-full">
                <div class="relative aspect-video overflow-hidden">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.imageAlt || post.data.title}
                      class="object-cover w-full h-full"
                    />
                  ) : (
                    <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200" />
                  )}
                </div>
                <div class="p-6">
                  <div class="flex flex-wrap gap-2 mb-3">
                    {post.data.categoria && (
                      <span class="text-sm px-3 py-1 bg-blue-50 text-blue-600 rounded-full">
                        {post.data.categoria}
                      </span>
                    )}
                    {post.data.dificultad && (
                      <span class="text-sm px-3 py-1 bg-gray-100 text-gray-600 rounded-full">
                        {post.data.dificultad}
                      </span>
                    )}
                  </div>
                  <h3 class="text-xl font-bold mb-3 line-clamp-2 hover:text-blue-600 transition-colors">
                    {post.data.title}
                  </h3>
                  <p class="text-gray-600 mb-4 line-clamp-2">
                    {post.data.description}
                  </p>
                  {post.data.tags && (
                    <div class="flex flex-wrap gap-2 mb-4">
                      {post.data.tags.map(tag => (
                        <span class="text-xs px-2 py-1 bg-gray-100 text-gray-600 rounded-full">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <div class="flex items-center justify-between text-sm text-gray-500">
                    <time datetime={post.data.date.toISOString()}>
                      {new Date(post.data.date).toLocaleDateString('es-ES', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                    {post.data.readingTime && (
                      <span>{post.data.readingTime} min de lectura</span>
                    )}
                  </div>
                  {post.data.tiempoImplementacion && (
                    <div class="mt-3 text-sm text-gray-500">
                      Tiempo de implementación: {post.data.tiempoImplementacion}
                    </div>
                  )}
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>
</Layout>