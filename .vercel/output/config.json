{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_server-islands\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/_image\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/send-email\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/automatizacion\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/bi\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/consultoria\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/ia\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/power-bi\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/servicios\\/sap\\/?$",
			"dest": "_render"
		}
	],
	"images": {
		"sizes": [
			640,
			750,
			828,
			1080,
			1200,
			1920,
			2048,
			3840
		],
		"domains": [],
		"remotePatterns": []
	}
}